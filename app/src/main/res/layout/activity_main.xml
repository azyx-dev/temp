<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button android:id="@+id/btnLinear" android:text="Linear Layout"/>
        <Button android:id="@+id/btnRelative" android:text="Relative Layout"/>
        <Button android:id="@+id/btnConstraint" android:text="Constraint Layout"/>
        <Button android:id="@+id/btnFrame" android:text="Frame Layout"/>
        <Button android:id="@+id/btnScroll" android:text="Scroll View"/>
        <Button android:id="@+id/btnTable" android:text="Table Layout"/>
        <Button android:id="@+id/btnColor" android:text="Color Change Program"/>
        <Button android:id="@+id/btnProfile" android:text="Profile Program"/>

    </LinearLayout>
</ScrollView>